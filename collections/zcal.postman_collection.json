{
  "item": [
    {
      "id": "f1a2b3c4-0001-4a00-9000-zcalwebhooks01",
      "name": "Webhooks (Outbound - Documentation Only)",
      "description": {
        "content": "Zcal does not publish a general-purpose public REST API. The only documented programmatic surface is outbound webhooks: Zcal POSTs a JSON payload to a subscriber URL you configure when a booking is created, rescheduled, or cancelled. The request below is documentation-only and represents the shape of that outbound webhook payload; it is NOT a Zcal-hosted endpoint you can call. Point {{webhookReceiverUrl}} at your own receiver to test delivery.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "f1a2b3c4-0002-4a00-9000-zcalwebhooks02",
          "name": "Booking event webhook (event.created / event.rescheduled / event.cancelled)",
          "request": {
            "name": "Booking event webhook",
            "description": {
              "content": "Outbound webhook Zcal sends to YOUR subscriber URL on booking lifecycle events. Event types: event.created, event.rescheduled, event.cancelled. The optional x-zcal-webhook-signature header is an HMAC SHA-256 hash of the payload signed with your secret key. This is not a callable Zcal API endpoint. See https://help.zcal.co/integrations/webhooks and https://help.zcal.co/integrations/webhooks/webhook-payload.",
              "type": "text/plain"
            },
            "url": {
              "raw": "{{webhookReceiverUrl}}",
              "host": [
                "{{webhookReceiverUrl}}"
              ],
              "path": [],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-zcal-webhook-signature",
                "value": "{{hmacSha256Signature}}"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"event.created\",\n  \"created_at\": \"2026-06-21T15:00:00Z\",\n  \"data\": {\n    \"id\": \"evt_example\",\n    \"eventName\": \"Intro Call\",\n    \"startDate\": \"2026-06-22T17:00:00Z\",\n    \"duration\": 30,\n    \"cancelled\": false,\n    \"hosts\": [{ \"name\": \"Host Name\", \"email\": \"host@example.com\" }],\n    \"attendees\": [{ \"name\": \"Invitee Name\", \"email\": \"invitee@example.com\", \"timezone\": \"America/New_York\", \"type\": \"invitee\" }],\n    \"location\": { \"type\": \"online\", \"url\": \"https://zoom.us/j/123\", \"id\": \"123\", \"passcode\": \"456\" }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          }
        }
      ],
      "event": []
    }
  ],
  "event": [],
  "variable": [
    {
      "type": "string",
      "value": "https://your-endpoint.example.com/zcal-webhook",
      "key": "webhookReceiverUrl"
    },
    {
      "type": "string",
      "value": "",
      "key": "hmacSha256Signature"
    }
  ],
  "info": {
    "_postman_id": "f1a2b3c4-0000-4a00-9000-zcalcollection0",
    "name": "Zcal",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Zcal scheduling platform. No public REST API is documented; the only programmatic surface is outbound webhooks (event.created, event.rescheduled, event.cancelled) posted to a subscriber URL you control. See https://help.zcal.co/integrations/webhooks",
      "type": "text/plain"
    }
  }
}
